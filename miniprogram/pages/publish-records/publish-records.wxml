<!-- 发布记录 publish-records.wxml -->
<view class="page-container">
  <!-- 筛选标签 -->
  <view class="filter-tabs">
    <view 
      class="filter-item {{filter === item ? 'active' : ''}}" 
      wx:for="{{['全部', '出售中', '已售出']}}" 
      wx:key="*this"
      bindtap="onFilterChange"
      data-filter="{{item}}"
    >
      <text>{{item}}</text>
      <view wx:if="{{filter === item}}" class="active-indicator"></view>
    </view>
  </view>

  <!-- 记录列表 -->
  <scroll-view scroll-y class="record-list" enhanced show-scrollbar="{{false}}">
    <view class="record-card" wx:for="{{records}}" wx:key="id">
      <view class="record-content">
        <view class="image-wrapper">
          <image class="record-image" src="{{item.image}}" mode="aspectFill"></image>
          <view class="status-badge {{item.status === '出售中' ? 'selling' : 'sold'}}">
            {{item.status}}
          </view>
        </view>
        <view class="record-info">
          <text class="record-title">{{item.title}}</text>
          <view class="record-stats">
            <view class="stat-item">
              <text>👁️</text>
              <text>{{item.views}} 浏览</text>
            </view>
            <view class="stat-item">
              <text>🕐</text>
              <text>{{item.time}}发布</text>
            </view>
          </view>
          <view class="record-price">
            <text class="current-price">¥{{item.price}}</text>
            <text class="original-price">¥{{item.originalPrice}}</text>
          </view>
        </view>
      </view>

      <view class="record-actions">
        <view class="delete-btn" catchtap="onDelete" data-id="{{item.id}}" data-status="{{item.statusCode}}">
          <text>🗑️</text>
        </view>
        <view class="action-btn primary blue" catchtap="onEdit" data-id="{{item.id}}">
          <text>✏️</text>
          <text>编辑商品</text>
        </view>
        <view wx:if="{{item.status === '出售中'}}" class="action-btn primary" catchtap="onPolish" data-id="{{item.id}}">
          擦亮曝光
        </view>
        <view wx:if="{{item.status === '已下架'}}" class="action-btn primary blue" catchtap="onRepublish" data-id="{{item.id}}">
          重新上架
        </view>
      </view>
    </view>

    <!-- 空提示 -->
    <view class="empty-hint">
      <text>⚠️</text>
      <text>没有更多内容了，去发布一本吧！</text>
    </view>
  </scroll-view>
</view>
