/* 发布记录样式 publish-records.wxss */

page {
  width: 100%;
  overflow-x: hidden;
}

.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f8fafc;
  width: 100%;
  overflow-x: hidden;
  box-sizing: border-box;
}

/* 头部 */
.header {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background-color: #ffffff;
  border-bottom: 2rpx solid #f1f5f9;
  position: sticky;
  top: 0;
  z-index: 50;
  width: 100%;
  box-sizing: border-box;
}

.back-btn {
  padding: 8rpx;
  margin-right: 16rpx;
}

.back-btn image {
  width: 48rpx;
  height: 48rpx;
  opacity: 0.4;
}

.header-title {
  font-size: 36rpx;
  font-weight: 900;
  color: #0f172a;
}

/* 筛选标签 */
.filter-tabs {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 48rpx;
  background-color: #ffffff;
  border-bottom: 2rpx solid #f8fafc;
  width: 100%;
  box-sizing: border-box;
}

.filter-item {
  position: relative;
  font-size: 28rpx;
  font-weight: 700;
  color: #94a3b8;
  padding-bottom: 16rpx;
  transition: color 0.2s;
}

.filter-item.active {
  color: #10b981;
}

.active-indicator {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 8rpx;
  background-color: #10b981;
  border-radius: 4rpx;
}

/* 记录列表 */
.record-list {
  flex: 1;
  padding: 32rpx;
  width: 100%;
  box-sizing: border-box;
}

.record-card {
  background-color: #ffffff;
  border-radius: 48rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  border: 2rpx solid #f1f5f9;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.02);
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}

/* 记录内容 */
.record-content {
  display: flex;
  gap: 32rpx;
  width: 100%;
  box-sizing: border-box;
}

.image-wrapper {
  position: relative;
}

.record-image {
  width: 160rpx;
  height: 224rpx;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.status-badge {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  font-size: 16rpx;
  font-weight: 900;
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.status-badge.selling {
  background-color: #10b981;
}

.status-badge.sold {
  background-color: #3b82f6;
}

.status-badge.reserved {
  background-color: #f59e0b;
}

.status-badge.off-shelf {
  background-color: #94a3b8;
}

.record-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 8rpx 0;
  min-width: 0;
  overflow: hidden;
}

.record-title {
  font-size: 28rpx;
  font-weight: 900;
  color: #0f172a;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
}

.record-stats {
  display: flex;
  gap: 24rpx;
  margin-top: 16rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.stat-item image {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.4;
}

.stat-item text {
  font-size: 20rpx;
  color: #94a3b8;
}

.record-price {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.current-price {
  font-size: 36rpx;
  font-weight: 900;
  color: #10b981;
}

.original-price {
  font-size: 20rpx;
  color: #cbd5e1;
  text-decoration: line-through;
}

/* 记录操作 */
.record-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  padding-top: 24rpx;
  margin-top: 24rpx;
  border-top: 2rpx solid #f8fafc;
  flex-wrap: wrap;
}

.delete-btn {
  padding: 16rpx;
}

.delete-btn image {
  width: 40rpx;
  height: 40rpx;
  opacity: 0.4;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  flex: 1;
  height: 80rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.action-btn image {
  width: 32rpx;
  height: 32rpx;
}

.action-btn.outline {
  border: 2rpx solid #f1f5f9;
  color: #64748b;
}

.action-btn.primary {
  background-color: #10b981;
  color: #ffffff;
  box-shadow: 0 16rpx 40rpx rgba(16, 185, 129, 0.2);
}

/* 空提示 */
.empty-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.5);
  border: 4rpx dashed #e2e8f0;
  border-radius: 48rpx;
  padding: 48rpx;
  margin-top: 16rpx;
}

.empty-hint image {
  width: 64rpx;
  height: 64rpx;
  opacity: 0.2;
  margin-bottom: 16rpx;
}

.empty-hint text {
  font-size: 20rpx;
  font-weight: 700;
  color: #94a3b8;
}
