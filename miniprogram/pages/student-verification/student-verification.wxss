/* тГдућЪУ«цУ»ЂТаит╝Ј student-verification.wxss */

page {
  width: 100%;
  overflow-x: hidden;
}

.page-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #ecfdf5;
  width: 100%;
  overflow-x: hidden;
  box-sizing: border-box;
}

/* тєЁт«╣тї║ */
.content-scroll {
  flex: 1;
}

.content-wrapper {
  position: relative;
  z-index: 20;
  padding: 0 40rpx 80rpx;
}

/* уіХТђЂтЇАуЅЄ */
.status-card {
  background-color: #ffffff;
  border-radius: 50rpx;
  padding: 48rpx;
  box-shadow: 0 24rpx 60rpx rgba(100, 116, 139, 0.1);
  border: 2rpx solid #f1f5f9;
  margin-bottom: 24rpx;
}

.status-content {
  text-align: center;
  padding: 32rpx 0;
}

.status-icon-wrapper {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 32rpx;
  border-width: 8rpx;
  border-style: solid;
}

.status-icon-wrapper.verified {
  background-color: #ecfdf5;
  border-color: #d1fae5;
}

.status-icon-wrapper.pending {
  background-color: #eff6ff;
  border-color: #dbeafe;
}

.status-icon-wrapper image {
  width: 64rpx;
  height: 64rpx;
}

.status-title {
  display: block;
  font-size: 36rpx;
  font-weight: 900;
  color: #0f172a;
}

.status-desc {
  display: block;
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 16rpx;
  line-height: 1.8;
  white-space: pre-line;
}

/* У«цУ»ЂТЮЃуЏі */
.benefits-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.benefit-item {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  padding: 24rpx;
  background-color: rgba(236, 253, 245, 0.5);
  border-radius: 32rpx;
}

.benefit-icon-wrapper {
  width: 72rpx;
  height: 72rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
  flex-shrink: 0;
}

.benefit-icon-wrapper image {
  width: 40rpx;
  height: 40rpx;
}

.benefit-info {
  flex: 1;
}

.benefit-title {
  display: block;
  font-size: 24rpx;
  font-weight: 900;
  color: #0f172a;
}

.benefit-desc {
  display: block;
  font-size: 20rpx;
  color: #64748b;
  margin-top: 4rpx;
}

/* УАетЇЋтЇАуЅЄ */
.form-card {
  background-color: #ffffff;
  border-radius: 50rpx;
  padding: 48rpx;
  box-shadow: 0 16rpx 40rpx rgba(100, 116, 139, 0.08);
  border: 2rpx solid #f1f5f9;
  margin-bottom: 24rpx;
}

.form-title {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 48rpx;
}

.form-title image {
  width: 32rpx;
  height: 32rpx;
}

.form-title text {
  font-size: 28rpx;
  font-weight: 900;
  color: #0f172a;
}

.form-fields {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.form-label {
  font-size: 20rpx;
  font-weight: 900;
  color: #94a3b8;
  text-transform: uppercase;
  letter-spacing: 4rpx;
  margin-left: 8rpx;
}

.form-input {
  height: 96rpx;
  padding: 0 32rpx;
  background-color: #f8fafc;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.input-placeholder {
  color: #cbd5e1;
  font-weight: 400;
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 96rpx;
  padding: 0 32rpx;
  background-color: #f8fafc;
  border-radius: 24rpx;
}

.form-picker text {
  font-size: 28rpx;
  font-weight: 700;
  color: #475569;
}

.form-picker image {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.3;
}

/* тЏЙуЅЄСИіС╝атї║тЪЪ - С╗┐уЁД publish жАхжЮб */
.image-upload-area {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.image-item {
  position: relative;
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.preview-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.delete-btn {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 56rpx;
  height: 56rpx;
  background-color: rgba(0, 0, 0, 0.6);
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 300;
}

.upload-item {
  width: 100%;
  min-height: 400rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 4rpx dashed #e2e8f0;
  border-radius: 24rpx;
  background-color: #f8fafc;
  transition: all 0.2s;
}

.upload-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.upload-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #475569;
  margin-bottom: 8rpx;
}

.upload-desc {
  font-size: 22rpx;
  color: #94a3b8;
  text-align: center;
  padding: 0 48rpx;
}

/* ТЈљС║цТїЅжњ« */
.submit-btn {
  width: 100%;
  height: 96rpx;
  background-color: #10b981 !important;
  color: #ffffff !important;
  font-size: 32rpx;
  font-weight: 900;
  border-radius: 32rpx;
  margin-top: 48rpx;
  border: none;
  transition: all 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 40rpx rgba(16, 185, 129, 0.25);
}

.submit-btn[disabled] {
  background-color: #10b981 !important;
  color: #ffffff !important;
}

.submit-btn::after {
  border: none;
}

/* жџљуДЂТЈљуц║ */
.privacy-note {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 32rpx 0;
}

.privacy-note image {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.3;
}

.privacy-note text {
  font-size: 20rpx;
  color: #cbd5e1;
}

/* М┼╗»║зх─│╔╣дм│├ТЛщ╩й */
.success-card {
  background: white;
  border-radius: 32rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.05);
  text-align: center;
  margin: 40rpx;
}

.success-icon-wrapper {
  width: 160rpx;
  height: 160rpx;
  background: #ecfdf5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 32rpx;
}

.success-icon {
  width: 80rpx;
  height: 80rpx;
}

.status-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 16rpx;
}

.status-desc {
  font-size: 28rpx;
  color: #64748b;
  margin-bottom: 48rpx;
}

.info-card {
  background: #f8fafc;
  border-radius: 24rpx;
  padding: 32rpx;
  text-align: left;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
}

.info-row .label {
  color: #64748b;
  font-size: 28rpx;
}

.info-row .value {
  color: #1e293b;
  font-weight: 600;
  font-size: 28rpx;
}

.divider {
  height: 1px;
  background: #e2e8f0;
  margin: 8rpx 0;
}
