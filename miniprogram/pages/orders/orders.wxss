/* 订单页样式 orders.wxss */

page {
  width: 100%;
  overflow-x: hidden;
}

.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f8fafc;
  width: 100%;
  overflow-x: hidden;
  box-sizing: border-box;
}

/* 头部 */
.tab-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 32rpx;
  background-color: #ffffff;
  width: 100%;
  box-sizing: border-box;
}

.tab-switch {
  display: flex;
  justify-content: center;
  background-color: #f1f5f9;
  border-radius: 32rpx;
  padding: 8rpx;
  width: 100%;
  max-width: 400rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  font-size: 24rpx;
  font-weight: 900;
  color: #94a3b8;
  border-radius: 24rpx;
  transition: all 0.2s;
}

.tab-item.active {
  background-color: #ffffff;
  color: #10b981;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* 筛选标签 */
.filter-tabs {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 48rpx;
  background-color: #ffffff;
  border-bottom: 2rpx solid #f8fafc;
  width: 100%;
  box-sizing: border-box;
}

.filter-item {
  position: relative;
  font-size: 28rpx;
  font-weight: 700;
  color: #94a3b8;
  padding-bottom: 16rpx;
  transition: color 0.2s;
}

.filter-item.active {
  color: #10b981;
}

.active-indicator {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 8rpx;
  background-color: #10b981;
  border-radius: 4rpx;
}

/* 订单列表 */
.order-list {
  flex: 1;
  padding: 32rpx;
  width: 100%;
  box-sizing: border-box;
}

.order-card {
  background-color: #ffffff;
  border-radius: 48rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  border: 2rpx solid #f1f5f9;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.02);
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}

/* 订单头部 */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #f8fafc;
  margin-bottom: 24rpx;
}

.order-party {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.party-icon {
  width: 32rpx;
  height: 32rpx;
}

.party-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #64748b;
}

.status-tag {
  font-size: 24rpx;
  font-weight: 900;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
}

.status-tag.pending {
  background-color: #fff7ed;
  color: #f97316;
}

.status-tag.payment {
  background-color: #eff6ff;
  color: #3b82f6;
}

.status-tag.completed {
  background-color: #ecfdf5;
  color: #10b981;
}

/* 订单内容 */
.order-content {
  display: flex;
  gap: 32rpx;
  margin-bottom: 24rpx;
}

.order-image {
  width: 128rpx;
  height: 160rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.order-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 8rpx 0;
  min-width: 0;
  overflow: hidden;
}

.order-title {
  font-size: 28rpx;
  font-weight: 900;
  color: #0f172a;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.order-time {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.order-time image {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.4;
}

.order-time text {
  font-size: 20rpx;
  color: #94a3b8;
}

.order-price {
  font-size: 28rpx;
  font-weight: 900;
  color: #10b981;
}

/* 订单操作 */
.order-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  padding-top: 16rpx;
  flex-wrap: wrap;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 32rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.action-btn image {
  width: 28rpx;
  height: 28rpx;
}

.action-btn.outline {
  border: 2rpx solid #f1f5f9;
  color: #64748b;
}

.action-btn.primary {
  background-color: #10b981;
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.2);
}

.action-btn.primary.blue {
  background-color: #3b82f6;
  box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.2);
}

.action-btn.primary.orange {
  background-color: #f97316;
  box-shadow: 0 8rpx 24rpx rgba(249, 115, 22, 0.2);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
  opacity: 0.3;
}

.empty-state image {
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 32rpx;
}

.empty-state text {
  font-size: 28rpx;
  font-weight: 700;
}

/* 底部 */
.list-footer {
  text-align: center;
  padding: 64rpx 0;
}

.list-footer text {
  font-size: 20rpx;
  font-weight: 700;
  color: #cbd5e1;
  text-transform: uppercase;
  letter-spacing: 4rpx;
}
