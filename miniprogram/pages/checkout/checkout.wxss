/* 结算页样式 checkout.wxss */

.page-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #f8fafc;
}

/* 成功视图 */
.success-view {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx;
  background-color: #ffffff;
}

.success-icon-wrapper {
  width: 160rpx;
  height: 160rpx;
  background-color: #ecfdf5;
  border: 8rpx solid #d1fae5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
}

.success-icon {
  width: 100rpx;
  height: 100rpx;
  font-size: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.success-title {
  font-size: 40rpx;
  font-weight: 900;
  color: #0f172a;
}

.success-desc {
  font-size: 28rpx;
  color: #94a3b8;
  margin-top: 16rpx;
}

/* 头部 */
.header {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background-color: #ffffff;
  position: sticky;
  top: 0;
  z-index: 50;
}

.back-btn {
  padding: 8rpx;
  margin-right: 16rpx;
}

.back-btn image {
  width: 48rpx;
  height: 48rpx;
  opacity: 0.4;
}

.header-title {
  font-size: 36rpx;
  font-weight: 900;
  color: #0f172a;
}

/* 内容区 */
.content-scroll {
  flex: 1;
}

.content-wrapper {
  padding: 40rpx;
  padding-bottom: 200rpx;
}

/* 商品卡片 */
.item-card {
  display: flex;
  background-color: #ffffff;
  padding: 32rpx;
  border-radius: 40rpx;
  border: 2rpx solid #f1f5f9;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.02);
  margin-bottom: 32rpx;
}

.item-image {
  width: 160rpx;
  height: 224rpx;
  border-radius: 32rpx;
  margin-right: 32rpx;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 8rpx 0;
}

.item-title {
  font-size: 28rpx;
  font-weight: 900;
  color: #0f172a;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.item-seller {
  font-size: 24rpx;
  color: #94a3b8;
}

.item-price {
  font-size: 36rpx;
  font-weight: 900;
  color: #10b981;
}

/* 安全提示 */
.safety-tips {
  display: flex;
  align-items: flex-start;
  background-color: rgba(255, 247, 237, 0.5);
  padding: 32rpx;
  border-radius: 40rpx;
  border: 2rpx solid rgba(254, 215, 170, 0.3);
  margin-bottom: 32rpx;
}

.tips-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 24rpx;
  margin-top: 4rpx;
  flex-shrink: 0;
}

.tips-content {
  flex: 1;
}

.tips-title {
  font-size: 22rpx;
  font-weight: 900;
  color: #9a3412;
  display: block;
  margin-bottom: 8rpx;
}

.tips-text {
  font-size: 22rpx;
  color: #9a3412;
  line-height: 1.6;
}

/* 支付方式卡片 */
.payment-card {
  background-color: #ffffff;
  padding: 48rpx;
  border-radius: 40rpx;
  border: 2rpx solid #f1f5f9;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.02);
  margin-bottom: 32rpx;
}

.card-label {
  font-size: 20rpx;
  font-weight: 900;
  color: #94a3b8;
  text-transform: uppercase;
  letter-spacing: 4rpx;
  display: block;
  margin-bottom: 32rpx;
}

.payment-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f1f5f9;
}

.payment-option:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.payment-option:first-of-type {
  padding-top: 0;
}

.payment-option:active {
  background-color: #f8fafc;
}

.payment-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.payment-icon-wrapper {
  width: 64rpx;
  height: 64rpx;
  background-color: #10b981;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.payment-icon {
  width: 40rpx;
  height: 40rpx;
}

.payment-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #475569;
}

.payment-radio {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 4rpx solid #e2e8f0;
  box-sizing: border-box;
}

.payment-radio.checked {
  border: 10rpx solid #10b981;
  background-color: #10b981;
}

/* 价格卡片 */
.price-card {
  background-color: #ffffff;
  padding: 48rpx;
  border-radius: 40rpx;
  border: 2rpx solid #f1f5f9;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.02);
}

.price-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.price-row:last-child {
  margin-bottom: 0;
}

.price-row.total {
  padding-top: 24rpx;
  border-top: 2rpx solid #f8fafc;
  margin-top: 8rpx;
}

.price-label {
  font-size: 28rpx;
  color: #94a3b8;
}

.price-row.total .price-label {
  font-size: 28rpx;
  font-weight: 900;
  color: #0f172a;
}

.price-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.price-value.free {
  color: #10b981;
}

.price-value.total-value {
  font-size: 40rpx;
  font-weight: 900;
  color: #10b981;
}

/* 底部按钮 */
.footer-btn {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  border-top: 2rpx solid #f8fafc;
}

.btn-group {
  display: flex;
  gap: 24rpx;
}

.cancel-btn {
  flex: 1;
  height: 112rpx;
  background-color: #f1f5f9;
  color: #64748b;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.cancel-btn::after {
  border: none;
}

.pay-btn {
  flex: 2;
  height: 112rpx;
  background-color: #10b981;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 900;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  border: none;
  box-shadow: 0 24rpx 60rpx rgba(16, 185, 129, 0.2);
}

.pay-btn::after {
  border: none;
}

.pay-btn.loading {
  opacity: 0.8;
}

.shield-icon,
.loading-icon {
  width: 40rpx;
  height: 40rpx;
}

.loading-icon {
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
