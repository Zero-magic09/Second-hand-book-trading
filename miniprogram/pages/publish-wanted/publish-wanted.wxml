<!-- 发布求购 publish-wanted.wxml -->
<view class="page-container">


  <scroll-view scroll-y class="form-scroll" enhanced show-scrollbar="{{false}}">
    <view class="form-card animate-in">
      <view class="form-header">
        <text class="header-icon">📢</text>
        <view class="header-text">
          <text class="header-h1">想找什么书？</text>
          <text class="header-p">填写详情，让有书的同学找到你</text>
        </view>
      </view>

      <!-- 书名 -->
      <view class="input-group">
        <view class="label">书籍名称 <text class="required">*</text></view>
        <view class="input-wrapper">
          <text class="input-icon">📖</text>
          <input class="modern-input" placeholder="请输入准确的书名" placeholder-class="placeholder-style" value="{{formData.title}}" bindinput="onInputChange" data-field="title" />
        </view>
      </view>

      <!-- 作者 -->
      <view class="input-group">
        <view class="label">作者 (选填)</view>
        <view class="input-wrapper">
          <text class="input-icon">✍️</text>
          <input class="modern-input" placeholder="输入作者更易匹配" placeholder-class="placeholder-style" value="{{formData.author}}" bindinput="onInputChange" data-field="author" />
        </view>
      </view>

      <!-- 价格与分类 -->
      <view class="row">
        <view class="input-group half">
          <view class="label">最高预算</view>
          <view class="input-wrapper">
            <text class="input-icon">💰</text>
            <input class="modern-input" type="digit" placeholder="面议" placeholder-class="placeholder-style" value="{{formData.maxPrice}}" bindinput="onInputChange" data-field="maxPrice" />
          </view>
        </view>

        <view class="input-group half">
          <view class="label">分类</view>
          <picker mode="selector" range="{{majors}}" bindchange="onMajorChange">
            <view class="input-wrapper picker-wrapper">
              <text class="input-icon">🏷️</text>
              <text class="picker-text">{{formData.category}}</text>
              <text class="picker-arrow">▼</text>
            </view>
          </picker>
        </view>
      </view>

      <!-- 描述 -->
      <view class="input-group">
        <view class="label">详细描述</view>
        <view class="textarea-wrapper">
          <textarea class="modern-textarea" placeholder="描述你对书况的要求，或者具体的版本信息..." placeholder-class="placeholder-style" value="{{formData.description}}" bindinput="onInputChange" data-field="description" maxlength="200"></textarea>
          <view class="word-count">{{formData.description.length || 0}}/200</view>
        </view>
      </view>

    </view>
  </scroll-view>

  <view class="footer-action">
    <button class="submit-btn" bindtap="onPublish">
      立即发布
    </button>
  </view>
</view>
