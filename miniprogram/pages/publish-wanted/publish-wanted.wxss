/* 发布求购样式 publish-wanted.wxss */
page {
  background-color: #f8fafc;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.page-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 顶部导航已使用原生 */


/* 表单滚动区 */
.form-scroll {
  flex: 1;
  padding: 16px;
  box-sizing: border-box;
}

.form-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(148, 163, 184, 0.1);
  margin-bottom: 24rpx;
}

/* 头部引导 */
.form-header {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx dashed #e2e8f0;
}

.header-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
  background: #ecfdf5;
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-text {
  display: flex;
  flex-direction: column;
}

.header-h1 {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 4rpx;
}

.header-p {
  font-size: 24rpx;
  color: #64748b;
}

/* 输入组 */
.input-group {
  margin-bottom: 32rpx;
}

.label {
  font-size: 28rpx;
  font-weight: 600;
  color: #334155;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
}

.required {
  color: #ef4444;
  margin-left: 4rpx;
}

.input-wrapper {
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  transition: all 0.2s;
}

.input-wrapper:active {
  border-color: #10b981;
  background: #ffffff;
}

.input-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.modern-input {
  flex: 1;
  font-size: 28rpx;
  color: #0f172a;
  height: 100%;
}

.placeholder-style {
  color: #94a3b8;
}

/* 一行两列 */
.row {
  display: flex;
  gap: 24rpx;
}

.half {
  flex: 1;
}

/* 选择器 */
.picker-wrapper {
  justify-content: space-between;
}

.picker-text {
  flex: 1;
  font-size: 28rpx;
  color: #0f172a;
}

.picker-arrow {
  color: #94a3b8;
  font-size: 24rpx;
}

/* 文本域 */
.textarea-wrapper {
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  padding: 24rpx;
  position: relative;
}

.modern-textarea {
  width: 100%;
  height: 200rpx;
  font-size: 28rpx;
  color: #0f172a;
  line-height: 1.5;
}

.word-count {
  position: absolute;
  bottom: 12rpx;
  right: 24rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

/* 底部按钮 */
.footer-action {
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -4rpx 16rpx rgba(148, 163, 184, 0.1);
}

.submit-btn {
  background: linear-gradient(135deg, #10b981, #059669);
  color: #ffffff;
  border-radius: 999rpx;
  font-size: 32rpx;
  font-weight: 600;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  transition: all 0.3s;
  box-shadow: 0 8rpx 20rpx rgba(16, 185, 129, 0.3);
}

.submit-btn:active {
  transform: scale(0.98);
}

/* 动画 */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.animate-in {
  animation: fadeIn 0.4s ease-out forwards;
}
