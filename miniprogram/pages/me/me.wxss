/* дёЄдєєдё­еїѓж ·ејЏ me.wxss */

.page-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #fafafa;
}

.content-scroll {
  flex: 1;
}

/* е¤ґйѓЁ */
.profile-header {
  background-color: #ffffff;
  padding: 64rpx 48rpx 48rpx;
  position: relative;
}

.header-actions {
  position: absolute;
  top: 32rpx;
  right: 32rpx;
  display: flex;
  gap: 16rpx;
}

.action-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn.admin {
  background-color: #ecfdf5;
}

.action-btn.settings {
  background-color: #f8fafc;
}

.action-icon {
  width: 40rpx;
  height: 40rpx;
}

/* з”Ёж€·дїЎжЃЇ */
.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 48rpx;
}

.avatar-wrapper {
  position: relative;
  margin-right: 32rpx;
}

.user-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 64rpx;
  border: 8rpx solid #ecfdf5;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.verified-badge {
  position: absolute;
  bottom: -8rpx;
  right: -8rpx;
  width: 48rpx;
  height: 48rpx;
  background-color: #10b981;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #ffffff;
}

.badge-icon {
  width: 28rpx;
  height: 28rpx;
}

.user-details {
  flex: 1;
}

.user-name {
  font-size: 40rpx;
  font-weight: 900;
  color: #0f172a;
  display: block;
}

.user-tag {
  display: inline-block;
  background-color: #f1f5f9;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 700;
  color: #64748b;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-top: 12rpx;
}

/* з»џи®ЎеЌЎз‰‡ */
.stats-card {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32rpx;
  background-color: rgba(248, 250, 252, 0.8);
  padding: 40rpx;
  border-radius: 44rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 900;
  margin-bottom: 8rpx;
}

.stat-value.text-emerald {
  color: #10b981;
}

.stat-value.text-blue {
  color: #3b82f6;
}

.stat-value.text-amber {
  color: #f59e0b;
}

.stat-label {
  font-size: 18rpx;
  font-weight: 700;
  color: #94a3b8;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

/* иЏњеЌ•йѓЁе€† */
.menu-section {
  padding: 0 40rpx;
  margin-top: 24rpx;
}

.menu-card {
  background-color: #ffffff;
  border-radius: 50rpx;
  border: 2rpx solid #f1f5f9;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.02);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx;
  border-bottom: 2rpx solid #f8fafc;
  transition: background-color 0.2s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: #f8fafc;
}

.menu-item.logout:active {
  background-color: #fef2f2;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.menu-icon-wrapper {
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-icon-wrapper.bg-indigo {
  background-color: #eef2ff;
}

.menu-icon-wrapper.bg-emerald {
  background-color: #ecfdf5;
}

.menu-icon-wrapper.bg-rose {
  background-color: #fff1f2;
}

.menu-icon-wrapper.bg-blue {
  background-color: #eff6ff;
}

.menu-icon-wrapper.bg-cyan {
  background-color: #ecfeff;
}

.menu-icon {
  width: 40rpx;
  height: 40rpx;
}

.menu-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #475569;
}

.menu-label.text-rose {
  color: #f43f5e;
}

.menu-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.menu-badge {
  background-color: #ecfdf5;
  color: #10b981;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 900;
  text-transform: uppercase;
}

.arrow-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.2;
}

/* еє•йѓЁ */
.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
}

.footer-brand {
  font-size: 20rpx;
  font-weight: 900;
  color: #e2e8f0;
  text-transform: uppercase;
  letter-spacing: 10rpx;
}

.footer-text {
  font-size: 18rpx;
  color: #cbd5e1;
  margin-top: 16rpx;
}

/* ±ај­µЇґ° */
.edit-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1;
}

.modal-content {
  position: relative;
  z-index: 2;
  width: 600rpx;
  background-color: #ffffff;
  border-radius: 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2);
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx;
  border-bottom: 2rpx solid #f1f5f9;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
}

.close-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: #f8fafc;
  font-size: 32rpx;
  color: #94a3b8;
}

.modal-body {
  padding: 40rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #64748b;
  margin-bottom: 16rpx;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.avatar-select {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  margin: 0 auto;
  border-radius: 50%;
  overflow: hidden;
}

.preview-avatar {
  width: 100%;
  height: 100%;
}

.avatar-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s;
}

.avatar-select:active .avatar-overlay {
  opacity: 1;
}

.overlay-text {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
}

.form-input {
  width: 100%;
  height: 96rpx;
  padding: 0 32rpx;
  border: 2rpx solid #e2e8f0;
  border-radius: 24rpx;
  font-size: 28rpx;
  color: #0f172a;
  background-color: #f8fafc;
}

.modal-footer {
  display: flex;
  gap: 16rpx;
  padding: 32rpx 40rpx 40rpx;
  border-top: 2rpx solid #f1f5f9;
}

.btn-cancel, .btn-save {
  flex: 1;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
}

.btn-cancel {
  background-color: #f1f5f9;
  color: #64748b;
}

.btn-save {
  background-color: #10b981;
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.3);
}

.btn-cancel::after, .btn-save::after {
  border: none;
}
