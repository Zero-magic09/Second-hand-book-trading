/* 求购区样式 wanted.wxss */

/* page {
  width: 100%;
  overflow-x: hidden;
} */
/* Removed page style causing double scrollbars sometimes, letting container handle it */

.page-container {
  min-height: 100vh;
  background-color: #fafafa;
  width: 100%;
  box-sizing: border-box;
  display: block;
}

.header {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  background-color: #ffffff;
  width: 100%;
  box-sizing: border-box;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.02); /* Added shadow for sticky header */
}

.header-title {
  display: flex;
  align-items: center;
}

.header-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
}

.title-text {
  font-size: 36rpx;
  font-weight: 900;
  color: #1e293b;
}

.publish-btn {
  display: flex;
  align-items: center;
  background-color: #10b981;
  color: #ffffff;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.2);
}

.plus-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 8rpx;
}

.btn-text {
  font-size: 24rpx;
  font-weight: 600;
}

.content-scroll {
  flex: 1;
  height: 0;
  padding: 0 32rpx 32rpx;
  width: 100%;
  box-sizing: border-box;
}

.wanted-list {
  margin-top: 16rpx;
  width: 100%;
  box-sizing: border-box;
}

.wanted-card {
  display: flex;
  background-color: #ffffff;
  padding: 32rpx;
  border-radius: 32rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid #f8fafc;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.02);
  box-sizing: border-box;
  width: 100%;
  overflow: hidden;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.card-content {
  flex: 1;
  min-width: 0;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.user-name {
  font-size: 24rpx;
  font-weight: 700;
  color: #1e293b;
}

.post-time {
  font-size: 20rpx;
  color: #94a3b8;
}

.wanted-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 16rpx;
  display: block;
}

.wanted-author {
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 12rpx;
  display: block;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tags {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
  flex: 1;
  min-width: 0;
}

.tag {
  font-size: 20rpx;
  font-weight: 500;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  white-space: nowrap;
}

.tag.budget {
  background-color: #fff7ed;
  color: #ea580c;
}

.tag.major {
  background-color: #f1f5f9;
  color: #64748b;
}

.action-btn {
  display: flex;
  align-items: center;
  color: #10b981;
  flex-shrink: 0;
}

.action-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 8rpx;
}

.action-text {
  font-size: 24rpx;
  font-weight: 600;
}

.tips-card {
  background-color: #ecfdf5;
  border: 2rpx dashed #a7f3d0;
  border-radius: 32rpx;
  padding: 48rpx;
  text-align: center;
  margin-top: 16rpx;
  width: 100%;
  box-sizing: border-box;
}

.tips-text {
  display: block;
  font-size: 24rpx;
  color: #047857;
  line-height: 1.8;
}
