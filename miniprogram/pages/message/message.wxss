/* 消息列表样式 message.wxss */

.page-container {
  min-height: 100vh;
  background-color: #ffffff;
  display: block;
}

/* 搜索框 */
.search-bar {
  position: sticky;
  top: 0;
  z-index: 100;
  background-color: #ffffff;
  padding: 32rpx;
  border-bottom: 2rpx solid #f8fafc;
}

.search-box {
  display: flex;
  align-items: center;
  background-color: #f8fafc;
  border-radius: 999rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 16rpx;
  opacity: 0.4;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #1e293b;
}

.search-placeholder {
  color: #94a3b8;
}

/* 聊天列表 */
.chat-list {
  width: 100%;
}

.chat-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid #f8fafc;
  transition: background-color 0.2s;
}

.chat-item:active {
  background-color: #f8fafc;
}

.avatar-wrapper {
  position: relative;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.chat-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 2rpx solid #f1f5f9;
}

.unread-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 8rpx;
  background-color: #ef4444;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #ffffff;
}

.chat-content {
  flex: 1;
  min-width: 0;
}

.chat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.chat-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1e293b;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chat-time {
  font-size: 20rpx;
  color: #94a3b8;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.chat-message {
  font-size: 24rpx;
  color: #64748b;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  opacity: 0.2;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #94a3b8;
}
