/* 首页样式 home.wxss */

.page-container {
  min-height: 100vh;
  background-color: #fafafa;
  display: block; /* Switch to block layout for natural scrolling */
}

/* 搜索头部 */
.search-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background-color: #ffffff;
  padding: 24rpx 32rpx;
  border-bottom: 2rpx solid #f1f5f9;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.02);
}

.search-box {
  display: flex;
  align-items: center;
  background-color: #f1f5f9;
  border-radius: 40rpx;
  padding: 20rpx 32rpx;
  height: 80rpx;
  box-sizing: border-box;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
  opacity: 0.5;
  line-height: 1;
  display: flex;
  align-items: center;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #1e293b;
  height: 40rpx;
  line-height: 40rpx;
}

.clear-icon {
  font-size: 28rpx;
  color: #94a3b8;
  padding: 8rpx 16rpx;
  margin-right: -16rpx;
}

.search-placeholder {
  color: #94a3b8;
}

/* 内容滚动区 */
.content-scroll {
  width: 100%;
}

.content-wrapper {
  padding: 32rpx;
}

/* Banner 卡片 */
.banner-card {
  position: relative;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  border-radius: 48rpx;
  padding: 40rpx;
  color: #ffffff;
  overflow: hidden;
  box-shadow: 0 16rpx 40rpx rgba(16, 185, 129, 0.2);
  margin-bottom: 32rpx;
}

.banner-content {
  position: relative;
  z-index: 10;
}

.banner-tag {
  display: inline-block;
  background-color: rgba(255, 255, 255, 0.2);
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 18rpx;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
}

.banner-title {
  font-size: 40rpx;
  font-weight: 900;
  margin-bottom: 16rpx;
}

.banner-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.5;
  max-width: 360rpx;
}

.banner-btn {
  display: inline-block;
  background-color: #ffffff;
  color: #10b981;
  padding: 12rpx 32rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
  margin-top: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.banner-bg {
  position: absolute;
  right: -60rpx;
  bottom: -60rpx;
  width: 300rpx;
  height: 300rpx;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  filter: blur(60rpx);
}

.banner-icon {
  position: absolute;
  right: 32rpx;
  top: 32rpx;
  width: 160rpx;
  height: 160rpx;
  opacity: 0.1;
  transform: rotate(12deg);
}

/* 快捷服务 */
.quick-service {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 32rpx;
  padding: 16rpx 0;
  margin-bottom: 32rpx;
}

.service-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.service-icon-wrapper {
  width: 96rpx;
  height: 96rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.service-icon-wrapper.bg-emerald {
  background-color: #d1fae5;
}

.service-icon-wrapper.bg-sky {
  background-color: #e0f2fe;
}

.service-icon-wrapper.bg-blue {
  background-color: #dbeafe;
}

.service-icon-wrapper.bg-rose {
  background-color: #ffe4e6;
}

.service-icon-wrapper.bg-amber {
  background-color: #fef3c7;
}

.service-icon {
  font-size: 40rpx;
  line-height: 1;
}

.service-label {
  font-size: 22rpx;
  font-weight: 600;
  color: #475569;
}

/* 分类区域 */
.section {
  margin-bottom: 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.section-title-wrapper {
  display: flex;
  align-items: center;
}

.section-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #1e293b;
}

.trending-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 8rpx;
}

.filter-btn {
  display: flex;
  align-items: center;
  color: #94a3b8;
}

.filter-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 8rpx;
}

.filter-text {
  font-size: 32rpx;
  font-weight: 900;
  color: #1e293b;
}

/* 分类标签 */
.category-scroll {
  white-space: nowrap;
}

.category-list {
  display: inline-flex;
  gap: 16rpx;
}

.category-item {
  display: inline-block;
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  font-weight: 700;
  background-color: #ffffff;
  color: #64748b;
  border: 2rpx solid #f1f5f9;
  transition: all 0.2s;
}

.category-item.active {
  background-color: #10b981;
  color: #ffffff;
  border-color: #10b981;
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.2);
}

/* 书籍网格 */
.book-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.book-card {
  background-color: #ffffff;
  border-radius: 48rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
  border: 2rpx solid rgba(241, 245, 249, 0.5);
}

.book-image-wrapper {
  position: relative;
  width: 100%;
  padding-top: 125%;
  overflow: hidden;
}

.book-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.book-tags {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.book-tag {
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 18rpx;
  font-weight: 700;
  color: #ffffff;
}

.book-tag.condition {
  background-color: rgba(0, 0, 0, 0.6);
}

.book-tag.major {
  background-color: #10b981;
}

.favorite-btn {
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  width: 48rpx;
  height: 48rpx;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.favorite-icon {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.4;
}

.book-info {
  padding: 24rpx;
}

.book-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1e293b;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  min-height: 80rpx;
  line-height: 1.4;
}

.book-meta {
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.meta-row {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: #64748b;
  line-height: 1.2;
}

.meta-icon, .meta-label {
  margin-right: 4rpx;
  font-size: 20rpx;
  color: #94a3b8; /* Lighter color for label */
  flex-shrink: 0;
}

.meta-text {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.book-location {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
}

.location-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 8rpx;
  opacity: 0.4;
}

.location-text {
  font-size: 20rpx;
  color: #94a3b8;
}

.book-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 2rpx solid #fafafa;
}

.book-price-wrapper {
  display: flex;
  flex-direction: column;
}

.book-price {
  font-size: 32rpx;
  font-weight: 900;
  color: #10b981;
}

.book-original-price {
  font-size: 18rpx;
  color: #cbd5e1;
  text-decoration: line-through;
}

.seller-info {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.seller-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #d1fae5;
}

.seller-name {
  font-size: 18rpx;
  color: #94a3b8;
  margin-top: 4rpx;
}

/* 列表底部 */
.list-footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.dot {
  width: 8rpx;
  height: 8rpx;
  background-color: #e2e8f0;
  border-radius: 50%;
  margin: 0 8rpx;
  display: inline-block;
}

.footer-text {
  font-size: 20rpx;
  color: #cbd5e1;
  margin-top: 16rpx;
}
