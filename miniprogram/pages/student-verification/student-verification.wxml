<!-- 学生认证 student-verification.wxml -->
<view class="page-container">
  <scroll-view scroll-y class="content-scroll" enhanced show-scrollbar="{{false}}">
    <view class="content-wrapper">
      <!-- 状态卡片 -->
      <view class="status-card">
        <!-- 已认证状态 -->
        <view wx:if="{{currentStatus === 'verified'}}" class="status-content verified">
          <view class="status-icon-wrapper verified">
            <text>🛡️</text>
          </view>
          <text class="status-title">您已完成认证</text>
          <text class="status-desc">浙江大学 · 计算机学院</text>
        </view>

        <!-- 步骤2：提交成功/审核中 -->
  <block wx:if="{{step === 2}}">
    <view class="success-card animate-in">
      <view class="success-icon-wrapper">
        <image class="success-icon" src="/images/icons/check-circle.png" wx:if="{{userInfo.verificationStatus === 2}}"></image>
        <image class="success-icon" src="/images/icons/clock.png" wx:else></image>
      </view>
      
      <view class="status-title">{{userInfo.verificationStatus === 2 ? '已通过学生认证' : '提交成功，审核中'}}</view>
      <view class="status-desc">{{userInfo.verificationStatus === 2 ? '您现在可以享受专属学生权益' : '管理员将在24小时内完成审核，请耐心等待'}}</view>
      
      <view class="info-card" wx:if="{{userInfo.verificationStatus === 2}}">
         <view class="info-row">
            <text class="label">姓名</text>
            <text class="value">{{userInfo.realName}}</text>
         </view>
         <view class="divider"></view>
         <view class="info-row">
            <text class="label">学校</text>
            <text class="value">{{userInfo.school}}</text>
         </view>
         <view class="divider"></view>
         <view class="info-row">
            <text class="label">学号</text>
            <text class="value">{{userInfo.studentId}}</text>
         </view>
      </view>
      
      <button class="btn-primary" bindtap="onBackToProfile" style="width:100%; margin-top: 40rpx;">返回个人中心</button>
    </view>
  </block>

        <!-- 认证权益 -->
        <view wx:else class="benefits-list">
          <view class="benefit-item" wx:for="{{benefits}}" wx:key="title">
            <view class="benefit-icon-wrapper">
              <text>{{item.emoji}}</text>
            </view>
            <view class="benefit-info">
              <text class="benefit-title">{{item.title}}</text>
              <text class="benefit-desc">{{item.desc}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 表单区域 -->
      <view wx:if="{{currentStatus === 'unverified' && step === 1}}" class="form-card">
        <view class="form-title">
          <text>👤</text>
          <text>填写认证信息</text>
        </view>

        <view class="form-fields">
          <view class="form-group">
            <text class="form-label">真实姓名</text>
            <input 
              class="form-input" 
              placeholder="请输入您的姓名"
              placeholder-class="input-placeholder"
              value="{{formData.name}}"
              bindinput="onInputChange"
              data-field="name"
            />
          </view>

          <view class="form-group">
            <text class="form-label">学号</text>
            <input 
              class="form-input" 
              placeholder="请输入学号"
              placeholder-class="input-placeholder"
              value="{{formData.studentId}}"
              bindinput="onInputChange"
              data-field="studentId"
            />
          </view>

          <view class="form-group">
            <text class="form-label">院系专业</text>
            <picker mode="selector" range="{{majors}}" bindchange="onMajorChange">
              <view class="form-picker">
                <text>{{formData.major}}</text>
                <text>▼</text>
              </view>
            </picker>
          </view>

          <view class="form-group">
            <text class="form-label">学生证照片</text>
            <view class="image-upload-area">
              <!-- 已选择的图片 -->
              <view class="image-item" wx:if="{{photoUrl}}">
                <image class="preview-image" src="{{photoUrl}}" mode="aspectFill"></image>
                <view class="delete-btn" catchtap="onDeletePhoto">×</view>
              </view>
              <!-- 添加照片按钮 -->
              <view class="upload-item" bindtap="onUploadPhoto" wx:if="{{!photoUrl}}">
                <text class="upload-icon">📷</text>
                <text class="upload-text">拍摄学生证正面</text>
                <text class="upload-desc">需清晰展示姓名、学院、入学年份及照片</text>
              </view>
            </view>
          </view>
        </view>

        <button 
          class="submit-btn {{canSubmit ? 'active' : ''}}" 
          bindtap="onSubmit"
          disabled="{{!canSubmit}}"
        >
          提交认证申请
        </button>
      </view>

      <!-- 隐私提示 -->
      <view class="privacy-note">
        <text>🔒</text>
        <text>您的身份信息受SSL加密保护，仅供认证使用</text>
      </view>
    </view>
  </scroll-view>
</view>
