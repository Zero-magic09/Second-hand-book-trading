/* app.wxss - 全局样式 */

/* Emoji 图标样式 */
.emoji {
  font-family: "Apple Color Emoji", "Segoe UI Emoji", "Noto Color Emoji", "Segoe UI Symbol", sans-serif;
  font-style: normal;
}

/* Emoji 图标大小 */
.emoji-xs { font-size: 24rpx; }
.emoji-sm { font-size: 28rpx; }
.emoji-base { font-size: 32rpx; }
.emoji-lg { font-size: 40rpx; }
.emoji-xl { font-size: 48rpx; }
.emoji-2xl { font-size: 56rpx; }
.emoji-3xl { font-size: 64rpx; }

/* 引入图标字体 */
@import '/styles/iconfont.wxss';

/* CSS 变量定义 */
page {
  --color-primary: #10b981;
  --color-primary-light: #d1fae5;
  --color-primary-dark: #059669;
  --color-secondary: #3b82f6;
  --color-warning: #f59e0b;
  --color-danger: #ef4444;
  --color-success: #22c55e;
  --color-text-primary: #1e293b;
  --color-text-secondary: #64748b;
  --color-text-light: #94a3b8;
  --color-bg-primary: #ffffff;
  --color-bg-secondary: #f8fafc;
  --color-border: #e2e8f0;
  
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: var(--color-text-primary);
  background-color: var(--color-bg-secondary);
  box-sizing: border-box;
}

/* 盒模型 */
view, text, image, button, input, textarea {
  box-sizing: border-box;
}

/* 按钮重置 */
button {
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  line-height: inherit;
}

button::after {
  border: none;
}

/* 图片 */
image {
  display: block;
}

/* 隐藏滚动条 */
::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  color: transparent;
}

/* 通用工具类 */
.flex {
  display: flex;
}

.flex-col {
  flex-direction: column;
}

.flex-row {
  flex-direction: row;
}

.flex-1 {
  flex: 1;
}

.flex-shrink-0 {
  flex-shrink: 0;
}

.items-center {
  align-items: center;
}

.items-start {
  align-items: flex-start;
}

.items-end {
  align-items: flex-end;
}

.justify-center {
  justify-content: center;
}

.justify-between {
  justify-content: space-between;
}

.justify-around {
  justify-content: space-around;
}

.justify-end {
  justify-content: flex-end;
}

.text-center {
  text-align: center;
}

.text-right {
  text-align: right;
}

.text-left {
  text-align: left;
}

/* 文本截断 */
.truncate {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.line-clamp-1 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
}

.line-clamp-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 圆角 */
.rounded-sm { border-radius: 8rpx; }
.rounded { border-radius: 12rpx; }
.rounded-md { border-radius: 16rpx; }
.rounded-lg { border-radius: 24rpx; }
.rounded-xl { border-radius: 32rpx; }
.rounded-2xl { border-radius: 40rpx; }
.rounded-3xl { border-radius: 48rpx; }
.rounded-full { border-radius: 50%; }

/* 阴影 */
.shadow-sm {
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.shadow {
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.shadow-md {
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.shadow-lg {
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.1);
}

.shadow-xl {
  box-shadow: 0 24rpx 60rpx rgba(0, 0, 0, 0.12);
}

/* 间距 */
.p-1 { padding: 8rpx; }
.p-2 { padding: 16rpx; }
.p-3 { padding: 24rpx; }
.p-4 { padding: 32rpx; }
.p-5 { padding: 40rpx; }
.p-6 { padding: 48rpx; }

.px-1 { padding-left: 8rpx; padding-right: 8rpx; }
.px-2 { padding-left: 16rpx; padding-right: 16rpx; }
.px-3 { padding-left: 24rpx; padding-right: 24rpx; }
.px-4 { padding-left: 32rpx; padding-right: 32rpx; }
.px-5 { padding-left: 40rpx; padding-right: 40rpx; }
.px-6 { padding-left: 48rpx; padding-right: 48rpx; }

.py-1 { padding-top: 8rpx; padding-bottom: 8rpx; }
.py-2 { padding-top: 16rpx; padding-bottom: 16rpx; }
.py-3 { padding-top: 24rpx; padding-bottom: 24rpx; }
.py-4 { padding-top: 32rpx; padding-bottom: 32rpx; }
.py-5 { padding-top: 40rpx; padding-bottom: 40rpx; }
.py-6 { padding-top: 48rpx; padding-bottom: 48rpx; }

.m-1 { margin: 8rpx; }
.m-2 { margin: 16rpx; }
.m-3 { margin: 24rpx; }
.m-4 { margin: 32rpx; }

.mx-1 { margin-left: 8rpx; margin-right: 8rpx; }
.mx-2 { margin-left: 16rpx; margin-right: 16rpx; }
.mx-3 { margin-left: 24rpx; margin-right: 24rpx; }
.mx-4 { margin-left: 32rpx; margin-right: 32rpx; }

.my-1 { margin-top: 8rpx; margin-bottom: 8rpx; }
.my-2 { margin-top: 16rpx; margin-bottom: 16rpx; }
.my-3 { margin-top: 24rpx; margin-bottom: 24rpx; }
.my-4 { margin-top: 32rpx; margin-bottom: 32rpx; }

.mb-1 { margin-bottom: 8rpx; }
.mb-2 { margin-bottom: 16rpx; }
.mb-3 { margin-bottom: 24rpx; }
.mb-4 { margin-bottom: 32rpx; }

.mt-1 { margin-top: 8rpx; }
.mt-2 { margin-top: 16rpx; }
.mt-3 { margin-top: 24rpx; }
.mt-4 { margin-top: 32rpx; }

.ml-1 { margin-left: 8rpx; }
.ml-2 { margin-left: 16rpx; }
.ml-3 { margin-left: 24rpx; }
.ml-4 { margin-left: 32rpx; }

.mr-1 { margin-right: 8rpx; }
.mr-2 { margin-right: 16rpx; }
.mr-3 { margin-right: 24rpx; }
.mr-4 { margin-right: 32rpx; }

/* 间隙 */
.space-x-1 > view:not(:first-child),
.space-x-1 > text:not(:first-child) { margin-left: 8rpx; }

.space-x-2 > view:not(:first-child),
.space-x-2 > text:not(:first-child) { margin-left: 16rpx; }

.space-x-3 > view:not(:first-child),
.space-x-3 > text:not(:first-child) { margin-left: 24rpx; }

.space-y-2 > view:not(:first-child) { margin-top: 16rpx; }
.space-y-3 > view:not(:first-child) { margin-top: 24rpx; }
.space-y-4 > view:not(:first-child) { margin-top: 32rpx; }
.space-y-6 > view:not(:first-child) { margin-top: 48rpx; }

/* 颜色 */
.text-primary { color: var(--color-primary); }
.text-secondary { color: var(--color-text-secondary); }
.text-light { color: var(--color-text-light); }
.text-white { color: #ffffff; }
.text-danger { color: var(--color-danger); }
.text-warning { color: var(--color-warning); }

.bg-primary { background-color: var(--color-primary); }
.bg-primary-light { background-color: var(--color-primary-light); }
.bg-white { background-color: #ffffff; }
.bg-gray { background-color: #f1f5f9; }

/* 额外的背景色类 */
.bg-emerald { background-color: rgba(16, 185, 129, 0.1); }
.bg-blue { background-color: rgba(59, 130, 246, 0.1); }
.bg-rose { background-color: rgba(244, 63, 94, 0.1); }
.bg-amber { background-color: rgba(245, 158, 11, 0.1); }
.bg-indigo { background-color: rgba(99, 102, 241, 0.1); }
.bg-cyan { background-color: rgba(6, 182, 212, 0.1); }
.bg-sky { background-color: rgba(14, 165, 233, 0.1); }
.bg-purple { background-color: rgba(168, 85, 247, 0.1); }

/* 文字颜色 */
.text-emerald { color: #10b981; }
.text-blue { color: #3b82f6; }
.text-rose { color: #f43f5e; }
.text-amber { color: #f59e0b; }
.text-indigo { color: #6366f1; }
.text-cyan { color: #06b6d4; }

/* 字体大小 */
.text-xs { font-size: 20rpx; }
.text-sm { font-size: 24rpx; }
.text-base { font-size: 28rpx; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 36rpx; }
.text-2xl { font-size: 40rpx; }
.text-3xl { font-size: 48rpx; }

/* 字重 */
.font-normal { font-weight: 400; }
.font-medium { font-weight: 500; }
.font-semibold { font-weight: 600; }
.font-bold { font-weight: 700; }
.font-black { font-weight: 900; }

/* 边框 */
.border { border: 2rpx solid var(--color-border); }
.border-t { border-top: 2rpx solid var(--color-border); }
.border-b { border-bottom: 2rpx solid var(--color-border); }
.border-gray { border-color: #f1f5f9; }
.border-primary { border-color: var(--color-primary); }

/* 宽高 */
.w-full { width: 100%; }
.h-full { height: 100%; }
.min-h-screen { min-height: 100vh; }

/* 定位 */
.relative { position: relative; }
.absolute { position: absolute; }
.fixed { position: fixed; }
.sticky { position: sticky; }
.top-0 { top: 0; }
.left-0 { left: 0; }
.right-0 { right: 0; }
.bottom-0 { bottom: 0; }
.z-10 { z-index: 10; }
.z-50 { z-index: 50; }

/* 溢出 */
.overflow-hidden { overflow: hidden; }
.overflow-auto { overflow: auto; }
.overflow-x-auto { overflow-x: auto; }
.overflow-y-auto { overflow-y: auto; }

/* 安全区域 */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 点击态 */
.active-scale {
  transition: transform 0.1s ease;
}

.active-scale:active {
  transform: scale(0.96);
}

/* 动画 */
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.animate-pulse {
  animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}

.animate-bounce {
  animation: bounce 2s ease-in-out infinite;
}

/* 分割线 */
.divider {
  height: 2rpx;
  background-color: #f1f5f9;
}

/* 胶囊标签 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.tag-primary {
  background-color: var(--color-primary-light);
  color: var(--color-primary);
}

.tag-warning {
  background-color: #fef3c7;
  color: #d97706;
}

.tag-gray {
  background-color: #f1f5f9;
  color: #64748b;
}

/* 按钮样式 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 32rpx;
  font-weight: 700;
  transition: all 0.2s;
}

.btn-primary {
  background-color: var(--color-primary);
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.25);
}

.btn-primary:active {
  background-color: var(--color-primary-dark);
  transform: scale(0.98);
}

.btn-outline {
  background-color: transparent;
  border: 2rpx solid var(--color-border);
  color: var(--color-text-secondary);
}

.btn-outline:active {
  background-color: #f8fafc;
}

.btn-ghost {
  background-color: transparent;
  color: var(--color-text-secondary);
}

.btn-ghost:active {
  background-color: #f1f5f9;
}

/* 输入框 */
.input {
  width: 100%;
  padding: 24rpx 32rpx;
  background-color: #f1f5f9;
  border-radius: 24rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.input-placeholder {
  color: #94a3b8;
}

/* 卡片 */
.card {
  background-color: #ffffff;
  border-radius: 48rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
  border: 2rpx solid #f1f5f9;
}
