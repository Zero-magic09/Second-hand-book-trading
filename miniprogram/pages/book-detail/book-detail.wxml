<!-- 书籍详情 book-detail.wxml -->
<view class="page-container">
  <!-- 头部图片 -->
  <view class="image-header">
    <image class="book-image" src="{{book.images[0] || defaultImage}}" mode="aspectFill" binderror="onImageError"></image>
  </view>

  <!-- 内容区域 -->
  <scroll-view scroll-y class="content-scroll" enhanced show-scrollbar="{{false}}">
    <view class="content-card">
      <!-- 价格和收藏 -->
      <view class="price-row">
        <view class="price-info">
          <view class="price-wrapper">
            <text class="current-price">¥{{book.price}}</text>
            <text class="original-price">¥{{book.originalPrice}}</text>
            <view class="discount-tag">{{discount}}折</view>
          </view>
          <text class="book-title">{{book.title}}</text>
        </view>
        <view class="favorite-btn" bindtap="onFavorite">
          <text class="favorite-icon">{{isFavorited ? '❤️' : '🤍'}}</text>
          <text class="favorite-text">{{isFavorited ? '已收藏' : '收藏'}}</text>
        </view>
      </view>

      <!-- 书籍信息网格 -->
      <view class="info-grid">
        <view class="info-item">
          <text class="info-label">品相</text>
          <text class="info-value">{{book.condition}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">所属专业</text>
          <text class="info-value">{{book.major}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">作者</text>
          <text class="info-value">{{book.author}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">推荐指数</text>
          <view class="info-value rating">
            <text>⭐⭐⭐⭐⭐</text>
          </view>
        </view>
      </view>

      <!-- 宝贝描述 -->
      <view class="description-section">
        <text class="section-title">宝贝描述</text>
        <text class="description-text">{{book.description || '这本教材保存得非常完好，主要用于期末复习，书中有少量的老师划线重点，非常适合学弟学妹复习使用。'}}</text>
      </view>

      <!-- 卖家信息 -->
      <view class="seller-card">
        <view class="seller-info">
          <image class="seller-avatar" src="{{book.sellerAvatar}}" mode="aspectFill"></image>
          <view class="seller-details">
            <text class="seller-name">用户：{{book.sellerName}}</text>
            <text class="seller-school" style="font-size: 24rpx; color: #64748b; font-weight: normal;">学校：{{book.sellerSchool}}</text>
          </view>
        </view>
        <view class="seller-btn">进入主页</view>
      </view>
    </view>
  </scroll-view>

  <!-- 底部操作栏 -->
  <view class="action-bar">
    <block wx:if="{{!isOwner}}">
      <view class="chat-btn" bindtap="onChat">
        <text class="chat-icon">💬</text>
        <text class="chat-text">聊一聊</text>
      </view>
      <view class="buy-btn" bindtap="onBuy">
        立即购买
      </view>
    </block>
    <block wx:else>
      <view class="buy-btn" style="width: 100%; background-color: #cbd5e1; transform: none;">
        这是您发布的商品
      </view>
    </block>
  </view>
</view>
